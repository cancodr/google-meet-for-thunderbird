{
  "manifest_version": 2,
  "name": "Google Meet Scheduler for Thunderbird",
  "version": "1.0",
  "description": "Schedule a Google Meet meeting directly from a Thunderbird message",

  "permissions": [
    "messagesRead",
    "accountsRead",
    "storage",
    "menus",
    "tabs",
    "addressBooks",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*"
  ],

  "background": {
    "scripts": [
      "config.js",
      "background.js"
    ]
  },

  "icons": {
    "64": "icons/icon-64.png"
  },

  "browser_action": {
    "default_title": "Google Meet Scheduler for Thunderbird",
    "default_icon": "icons/icon-64.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "google-meet-for-thunderbird@cancodr.github.io",
      "strict_min_version": "78.0"
    }
  }
}
